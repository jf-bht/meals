# EXPO_PUBLIC_-Präfix wird von Expo zur Build-Zeit in den JS-Bundle
# eingebettet. iOS-Simulator/Web: localhost funktioniert direkt.
# Android-Emulator: localhost muss durch 10.0.2.2 ersetzt werden.
EXPO_PUBLIC_MATCHING_SERVICE_URL=http://localhost:3001
EXPO_PUBLIC_GROCERY_SERVICE_URL=http://localhost:3002
